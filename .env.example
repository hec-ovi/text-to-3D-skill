# cp .env.example .env
#
# The container reaches the GPU through the render node, so it needs the host's
# real group ids. Read them with:
#   getent group render | cut -d: -f3
#   getent group video  | cut -d: -f3
RENDER_GID=990
VIDEO_GID=44

# Where scripts/fetch-models.sh put the TRELLIS.2 GGUFs (about 16 GiB).
TRELLIS_MODELS=/home/hec/models/gguf/trellis2

# Host directory the engine container can write into.
OUT_DIR=./out

# Host port for the resident engine.
ENGINE_PORT=8189
