{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "image2mesh/error.json",
  "title": "Image2MeshError",
  "description": "Closed error set for the image2mesh layer.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "code", "message"],
  "properties": {
    "contractVersion": { "type": "string", "const": "1.0" },
    "code": {
      "type": "string",
      "enum": [
        "INVALID_REQUEST",
        "IMAGE_MISSING",
        "CHECKSUM_MISMATCH",
        "MODELS_MISSING",
        "NO_VULKAN_DEVICE",
        "ENGINE_FAILED",
        "ENGINE_UNREACHABLE",
        "TIMEOUT",
        "OUTPUT_WRITE_FAILED",
        "GLB_INVALID"
      ]
    },
    "message": { "type": "string" },
    "detail": { "type": "string" }
  }
}
